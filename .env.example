# Supabase
# 取得元: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# サーバーサイド専用(絶対にクライアントに露出させないこと、NEXT_PUBLIC_ を付けない)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Resend(顧客入力完了時の事務所通知メール)
# 取得元: https://resend.com/api-keys
# 未設定でもフォーム送信自体は成功するが、メール通知はスキップされる(サーバーログに警告が出る)
RESEND_API_KEY=re_...your-resend-api-key...
RESEND_FROM_EMAIL=noreply@your-verified-domain.example
OFFICE_NOTIFICATION_EMAIL=office@your-office.example

# 通知メール本文の管理画面リンク生成に使う(本番は Vercel のURL)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
